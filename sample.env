# ═══════════════════════════════════════════════════════════════════════════════
# بوت إدارة المجموعات - ملف إعدادات البيئة
# ═══════════════════════════════════════════════════════════════════════════════

# 🤖 إعدادات البوت الأساسية
# ─────────────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
OWNER_ID=your_user_id_here
ADMIN_GROUP_ID=admin_group_id_here

# 🔐 إعدادات الأمان
# ─────────────────────────────────────────────────────────────────────────────
DEBUG_MODE=False
LOG_LEVEL=INFO

# 📊 إعدادات قاعدة البيانات
# ─────────────────────────────────────────────────────────────────────────────
DB_PATH=bans.db

# 🎵 إعدادات الموسيقى والفيديو
# ─────────────────────────────────────────────────────────────────────────────
MAX_FILE_MB=45
ENABLE_MUSIC_DOWNLOAD=True
ENABLE_VIDEO_DOWNLOAD=True

# 📧 إعدادات الإخطارات
# ─────────────────────────────────────────────────────────────────────────────
ENABLE_ADMIN_NOTIFICATIONS=True
ENABLE_DAILY_REPORTS=True
ENABLE_WEEKLY_REPORTS=True

# 🎮 إعدادات الألعاب
# ─────────────────────────────────────────────────────────────────────────────
ENABLE_FOCUS_GAME=True
MAX_GAME_SCORE=1000

# 🌍 إعدادات أخرى
# ─────────────────────────────────────────────────────────────────────────────
TIMEZONE=Asia/Baghdad
LANGUAGE=ar
