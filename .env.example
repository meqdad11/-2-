# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# بوت تليجرام شفق - ملف متغيرات البيئة
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# رمز البوت من BotFather
# احصل عليه من: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# معرف المالك (يوزر آيدي الخاص بك)
# احصل عليه بإرسال /id للبوت
OWNER_ID=123456789

# (اختياري) معرف مجموعة المشرفين الافتراضية
ADMIN_GROUP_ID=

# (اختياري) مفتاح API خارجي إذا احتجت
# مثل: API KEY للخدمات الإضافية
EXTERNAL_API_KEY=

# (اختياري) وضع التطوير (true/false)
DEBUG_MODE=false

# (اختياري) مستوى السجلات (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
